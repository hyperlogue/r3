source_up_secure() {
  eval "$(cd .. && env -uDIRENV_{DIR,FILE,WATCHES,DIFF} direnv export bash)"
}
source_up_secure

watch_file nix/shell.nix
watch_file nix/overlay/default.nix
use flake

watch_file bun.lock
bun install

# Run process-compose's control server over a per-project unix socket instead
# of TCP :8080, so multiple project stacks coexist with zero port collisions.
# Setting PC_SOCKET_PATH alone switches it to UDS (no --use-uds flag needed);
# every `process-compose` subcommand in this dir picks it up automatically.
export PC_SOCKET_PATH="/tmp/pc-r3.sock"

dotenv_if_exists
